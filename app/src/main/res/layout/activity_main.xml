<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ts_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ts_surface"
            app:cardCornerRadius="0dp"
            app:cardElevation="16dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:id="@+id/hud_inner_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/hud_padding_h"
                android:paddingVertical="@dimen/hud_padding_v"
                android:gravity="center_vertical"
                android:background="@drawable/bg_hud">

                <TextView
                    android:id="@+id/tv_hud_money"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/ts_gold"
                    android:textSize="@dimen/hud_text_primary"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:text="💰 $0"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="@dimen/hud_separator_height"
                    android:background="@drawable/bg_hud_separator"
                    android:layout_marginHorizontal="12dp" />

                <TextView
                    android:id="@+id/tv_hud_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ts_purple_bright"
                    android:textSize="@dimen/hud_text_primary"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="14dp"
                    android:text="Lv.1" />

                <TextView
                    android:id="@+id/tv_hud_xp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ts_text_dim"
                    android:textSize="@dimen/hud_text_secondary"
                    android:fontFamily="monospace"
                    android:text="XP 0" />

                <TextView
                    android:id="@+id/tv_hud_tick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/ts_text_muted"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="10dp"
                    android:text="T:0" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A8B5CF6" />

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A8B5CF6" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/ts_surface"
            app:itemIconTint="@color/bottom_nav_item_color"
            app:itemTextColor="@color/bottom_nav_item_color"
            app:itemIconSize="22dp"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/notification_host"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingHorizontal="16dp"
        android:paddingBottom="96dp"
        android:clipChildren="false"
        android:clipToPadding="false" />

</FrameLayout>
