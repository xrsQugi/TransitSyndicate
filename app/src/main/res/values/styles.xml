<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/ts_card</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="strokeColor">@color/ts_border</item>
        <item name="strokeWidth">@dimen/card_stroke_width</item>
        <item name="cardElevation">0dp</item>
        <item name="android:layout_marginHorizontal">@dimen/card_margin_h</item>
        <item name="android:layout_marginBottom">@dimen/card_margin_v</item>
    </style>

    <style name="Widget.App.Card.Accent">
        <item name="strokeColor">@color/ts_border_accent</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ts_purple</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/btn_corner_radius</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:minHeight">@dimen/btn_height_md</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
    </style>

    <style name="Widget.App.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/ts_border_accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/ts_purple_bright</item>
        <item name="rippleColor">@color/ts_purple_container</item>
        <item name="cornerRadius">@dimen/btn_corner_radius</item>
        <item name="android:minHeight">@dimen/btn_height_md</item>
    </style>

    <style name="Widget.App.Button.Danger" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/ts_red_dim</item>
        <item name="android:textColor">@color/ts_red</item>
        <item name="rippleColor">#33EF4444</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
    </style>

    <style name="Widget.App.Button.Success" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/ts_green_dim</item>
        <item name="android:textColor">@color/ts_green</item>
        <item name="rippleColor">#3310B981</item>
        <item name="cornerRadius">@dimen/btn_corner_radius</item>
        <item name="android:minHeight">@dimen/btn_height_sm</item>
        <item name="android:textSize">@dimen/text_sm</item>
    </style>

    <style name="Widget.App.Button.Chip" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/ts_card_elevated</item>
        <item name="android:textColor">@color/ts_text</item>
        <item name="strokeColor">@color/ts_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingStart">@dimen/spacing_sm</item>
        <item name="android:paddingEnd">@dimen/spacing_sm</item>
        <item name="android:lines">2</item>
        <item name="iconGravity">textStart</item>
    </style>

    <style name="Widget.App.Button.Upgrade" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/ts_orange_dim</item>
        <item name="android:textColor">@color/ts_orange</item>
        <item name="rippleColor">#33F59E0B</item>
        <item name="cornerRadius">10dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
    </style>

    <style name="TextAppearance.App" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/ts_text</item>
    </style>

    <style name="TextAppearance.App.SectionTitle">
        <item name="android:textSize">@dimen/section_text_size</item>
        <item name="android:textColor">@color/ts_text</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.App.CardTitle">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/ts_text</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Caption">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/ts_text_dim</item>
    </style>

    <style name="TextAppearance.App.CaptionXS">
        <item name="android:textSize">@dimen/text_xs</item>
        <item name="android:textColor">@color/ts_text_muted</item>
    </style>

    <style name="TextAppearance.App.Accent">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/ts_text_accent</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Gold">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/ts_gold</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.App.HudValue">
        <item name="android:textSize">@dimen/hud_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.App.EmptyState">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/ts_text_muted</item>
        <item name="android:gravity">center</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
        <item name="android:padding">@dimen/spacing_xxxl</item>
    </style>

    <style name="Widget.App.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="android:background">@color/ts_surface</item>
        <item name="itemBackground">@null</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemIconSize">22dp</item>
    </style>

    <style name="Widget.App.ProgressBar.Horizontal" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:layout_height">@dimen/progress_height</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:progressBackgroundTint">@color/ts_border</item>
        <item name="android:max">100</item>
    </style>

</resources>
